---
import { getSecret } from "astro:env/server";
import Star from "@lucide/astro/icons/star";

interface Props {
  owner?: string;
  repo: string;
}

const { owner = "warbacon", repo } = Astro.props;

const GITHUB_TOKEN = getSecret("GITHUB_TOKEN");

const res = await fetch(`https://api.github.com/repos/${owner}/${repo}`, {
  method: "GET",
  headers: {
    Accept: "application/vnd.github+json",
    Authorization: `Bearer ${GITHUB_TOKEN}`,
    "X-GitHub-Api-Version": "2022-11-28",
  },
});

if (!res.ok) {
  throw new Error(`GitHub API error: ${res.status} ${res.statusText}`);
}

const repoData = await res.json();
---

<a
  href={`https://github.com/${owner}/${repo}`}
  class="flex flex-col gap-2 border-1 border-zinc-300 bg-zinc-100 p-3 transition-[border-color,scale] hover:border-zinc-400 active:scale-98 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-zinc-600"
>
  <div class="flex justify-between">
    <h2 class="text-xl font-bold">{repoData.name}</h2>
    <div class="flex items-center gap-1 text-amber-700 dark:text-amber-300">
      <Star size={18} class="fill-current" />
      <p>{repoData.stargazers_count}</p>
    </div>
  </div>
  <p class="text-zinc-700 dark:text-zinc-300">{repoData.description}</p>
</a>
